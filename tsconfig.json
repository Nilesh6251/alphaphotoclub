{
  "compilerOptions": {
    "target": "ES2023",
    "module": "Node16",
    "moduleResolution": "node16",
    "allowJs": true,
    "checkJs": false,
    "noEmit": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true
  },
  "include": [
    "backend/**/*",
    "Apex-Photo-Club/**/*"
  ],
  "exclude": [
    "node_modules",
    "backend/node_modules",
    "Apex-Photo-Club/node_modules",
    "dist"
  ]
}
