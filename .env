# Backend Port
PORT=5000

# MongoDB Connection String (Replace with your Atlas URI if you want it online)
# For local development: mongodb://127.0.0.1:27017/apexphotoclub
MONGODB_URI=mongodb://127.0.0.1:27017/apexphotoclub

# Email Configuration for Nodemailer (e.g. Gmail)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
# Replace with your email (e.g. your_email@gmail.com)
EMAIL_USER=
# Replace with your App Password (NOT your regular email password)
EMAIL_PASS=
# The email address that will receive the contact inquiries
OWNER_EMAIL=
